      "targets": [
        {
          "expr": "sum by (service, method, route, status_class) (rate(ofm_http_requests_total{service=~\"$service\",env=~\"$env\"}[$__rate_interval]))",
          "legendFormat": "{{service}} {{method}} {{route}} {{status_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
