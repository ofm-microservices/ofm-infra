      "targets": [
        {
          "expr": "100 * sum by (service, keyspace) (rate(ofm_redis_cache_hits_total{service=~\"$service\",env=~\"$env\"}[$__rate_interval])) / clamp_min(sum by (service, keyspace) (rate(ofm_redis_cache_hits_total{service=~\"$service\",env=~\"$env\"}[$__rate_interval]) + rate(ofm_redis_cache_misses_total{service=~\"$service\",env=~\"$env\"}[$__rate_interval])), 0.001)",
