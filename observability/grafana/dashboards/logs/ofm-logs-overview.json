{
  "uid": "ofm-logs-overview",
  "title": "OFM Logs Overview",
  "tags": ["ofm", "logs", "production"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 2,
  "refresh": "15s",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "SELECT DISTINCT service FROM ofm_logs ORDER BY service",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "env",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "SELECT DISTINCT env FROM ofm_logs ORDER BY env",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "module",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "SELECT DISTINCT module FROM ofm_logs ORDER BY module",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "level",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "SELECT DISTINCT level FROM ofm_logs ORDER BY level",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Logs In Last 5m",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count() AS value FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors In Last 5m",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count() AS value FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') AND lower(level) IN ('error', 'fatal')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Log Rate",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT toStartOfFiveMinute(timestamp) AS time, count() AS value FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') AND lower(level) IN ('error', 'fatal') GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Logs By Level",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT level AS metric, count() AS value FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') GROUP BY level ORDER BY value DESC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "basic",
        "showUnfilled": true,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent Errors",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT timestamp, service, env, module, operation, level, attempt, retryable, duration_ms, msg, error, trace_id, span_id FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') AND lower(level) IN ('error', 'fatal') ORDER BY timestamp DESC LIMIT 100"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "timestamp",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Slow Logs",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT timestamp, service, env, module, operation, level, duration_ms, msg, trace_id, span_id FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') AND duration_ms > 0 ORDER BY duration_ms DESC LIMIT 100"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "duration_ms",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Logs By Service And Module",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT service, env, module, count() AS logs, countIf(lower(level) IN ('error', 'fatal')) AS errors, max(timestamp) AS last_seen FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') GROUP BY service, env, module ORDER BY logs DESC LIMIT 100"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "logs",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent Logs",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT timestamp, service, env, level, module, operation, attempt, retryable, duration_ms, msg, trace_id, span_id FROM ofm_logs WHERE $__timeFilter(timestamp) AND match(service, '^(${service:regex})$') AND match(env, '^(${env:regex})$') ORDER BY timestamp DESC LIMIT 200"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "timestamp",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "text",
      "title": "How To Use This Dashboard",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "options": {
        "content": "Use the tables to find the failing service, module, operation, and trace_id. Open the matching trace in Grafana Tempo or Drilldown -> Traces. Slow Logs shows the most expensive log-associated work. Recent Errors is the fastest way to jump from a failure row to a trace.",
        "mode": "markdown"
      }
    }
  ]
}
